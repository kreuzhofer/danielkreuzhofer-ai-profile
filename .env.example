# =============================================================================
# Environment Variables Configuration
# =============================================================================
#
# Single .env file for both Docker and local development.
#
# Setup:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Fill in your values (especially OPENAI_API_KEY)
#
# Running with Docker:
#   docker compose --profile development up -d
#
# Running locally (without Docker):
#   cd frontend && npm run dev:local
#   (uses dotenv-cli to load ../.env)
#
# IMPORTANT: Never commit .env files to version control!
#
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Node.js environment: do NOT set NODE_ENV here. `next dev` and `next build`
# set it automatically (development / production), and docker-compose sets it
# per service. Pinning NODE_ENV=development breaks `npm run build:local`
# (a production `next build` under NODE_ENV=development fails static prerender
# with a React "Cannot read properties of null (reading 'useReducer')" error).

# Port the application runs on
# Default: 8087
PORT=8087

# Hostname to bind to (use 0.0.0.0 for Docker)
# Default: 0.0.0.0
HOSTNAME=0.0.0.0

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------

# Log level controls verbosity of application logs
# Options: debug, info, warn, error
# Default: info (development), warn (production when NODE_ENV=production)
# Set to 'info' in production to see operational logs
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# AI Chatbot Configuration (OpenAI)
# -----------------------------------------------------------------------------

# OpenAI API Key (REQUIRED for chatbot functionality)
# Get your key at: https://platform.openai.com/api-keys
# Format: sk-...
OPENAI_API_KEY=

# OpenAI Model to use for chat completions
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# Default: gpt-4o-mini (cost-effective, good quality)
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Optional: Advanced LLM Settings (set in code, not typically overridden)
# -----------------------------------------------------------------------------
# These are configured with sensible defaults in the LLM client:
#
# Temperature: 0.7 (controls randomness, 0-2)
# Max Tokens: 1024 (maximum response length)
# Timeout: 30000ms (request timeout)
#
# To customize, modify frontend/src/lib/llm-client.ts

# -----------------------------------------------------------------------------
# Private Knowledge Repository (for Portainer/CI deployments)
# -----------------------------------------------------------------------------

# Provide these to fetch private knowledge repo at build time
# KNOWLEDGE_REPO: URL to your private knowledge repo (both formats work):
#   - github.com/username/private-knowledge.git
#   - https://github.com/username/private-knowledge.git
# GITHUB_TOKEN: Fine-grained personal access token with "Contents: Read" permission
# KNOWLEDGE_REPO=github.com/yourusername/private-knowledge.git
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Engpass-Check Funnel: Database (Postgres) + Email (SMTP)
# -----------------------------------------------------------------------------
#
# The Engpass-Check now runs its own opt-in funnel: it persists submissions in
# Postgres, runs its own Double-Opt-in, and sends a personalized report link by
# email. CleverReach (below) is only used for the ongoing newsletter after DOI.
#
# Base URL used to build links in emails (no trailing slash).
BASE_URL=http://localhost:8087
#
# Postgres connection. In Docker the `postgres` service is reachable as host
# `postgres`; locally use `localhost`. POSTGRES_* feed the docker postgres service.
DATABASE_URL=postgres://dbuser:dbpass@localhost:5432/danielkreuzhofer
# POSTGRES_USER=dbuser
# POSTGRES_PASSWORD=dbpass
# POSTGRES_DB=danielkreuzhofer
# POSTGRES_PORT=5432
#
# SMTP for transactional email (DOI confirmation + report delivery).
# Production: IONOS (smtp.ionos.de, port 587 STARTTLS). For local dev use
# Mailtrap (https://mailtrap.io). Without these, submissions are stored but no
# email is sent (the opt-in returns a 503).
# SMTP_HOST=smtp.ionos.de
# SMTP_PORT=587
# SMTP_SECURE=false           # false for 587 (STARTTLS); true only for 465
# SMTP_USER=daniel@kreuzhofer.de
# SMTP_PASSWORD=
# SMTP_FROM=daniel@kreuzhofer.de
#
# Retention job: shared secret for the scheduler that deletes UNCONFIRMED
# submissions after 7 days. Trigger e.g. daily: GET /api/cron/purge?secret=...
# (or Authorization: Bearer ...). Without it the endpoint returns 401.
# CRON_SECRET=

# -----------------------------------------------------------------------------
# Engpass-Check Newsletter push (CleverReach REST API v3)
# -----------------------------------------------------------------------------
#
# After OUR own Double-Opt-in confirms a lead, they are pushed to the CleverReach
# newsletter group as an ACTIVE receiver. Hybrid model → no CleverReach DOI form
# needed, only 3 keys. Without these, the confirm step simply skips the push
# (best-effort; the lead still gets the report).
#
# Create an OAuth client under CleverReach → My Account → Extras → REST API.
# CLIENT_ID / CLIENT_SECRET: OAuth client credentials (client_credentials grant)
# GROUP_ID: the receiver group for the newsletter
# CLEVERREACH_CLIENT_ID=
# CLEVERREACH_CLIENT_SECRET=
# CLEVERREACH_GROUP_ID=
#
# Optional overrides (defaults shown):
# CLEVERREACH_BASE_URL=https://rest.cleverreach.com
# CLEVERREACH_TOKEN_URL=https://rest.cleverreach.com/oauth/token.php

# -----------------------------------------------------------------------------
# Engpass-Check Attribution (trackmysales)
# -----------------------------------------------------------------------------
#
# After OUR own Double-Opt-in confirms a lead, the app reports the conversion to
# trackmysales (server-to-server) so it is attributed (final-touch) to the
# originating click/video. The visitor id (tid) is captured from ?tid on landing
# and stored with the submission. Without these three the report step simply
# skips the call (best-effort; the lead still gets the report).
#
# TRACKMYSALES_BASE_URL: base URL of the trackmysales API (no trailing slash)
# TRACKMYSALES_CONVERSION_CODE: the email_list ConversionLink code (e.g. engpass-check)
# TRACKMYSALES_CONVERSION_SECRET: shared secret = LEAD_CONVERSION_SECRET on trackmysales
# TRACKMYSALES_BASE_URL=
# TRACKMYSALES_CONVERSION_CODE=
# TRACKMYSALES_CONVERSION_SECRET=

# -----------------------------------------------------------------------------
# Future Configuration (placeholder for upcoming features)
# -----------------------------------------------------------------------------

# Analytics tracking ID (optional)
# ANALYTICS_ID=

# Contact form email recipient (optional)
# CONTACT_EMAIL=
