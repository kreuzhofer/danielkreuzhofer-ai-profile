    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -e ../.env -- drizzle-kit migrate",
    "db:studio": "dotenv -e ../.env -- drizzle-kit studio"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "@openai/guardrails": "^0.2.1",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "next": "^16.2.2",
    "nodemailer": "^8.0.11",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
