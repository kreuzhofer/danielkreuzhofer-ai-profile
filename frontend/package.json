{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "dotenv -e ../.env -- next dev",
    "build": "next build",
    "build:local": "dotenv -e ../.env -- next build",
    "start": "next start",
    "start:local": "dotenv -e ../.env -- next start",
